---
import type { Lang } from "../i18n/i18n";
import { t, i18nText, i18nTextLoc, i18nAttr } from "../i18n/i18n";
import { personal } from "../data/personal";
import { yearsSince } from "../lib/experience";
import { Image } from "astro:assets";
import diegoPhoto from "../assets/diego.png";
import diegoComic from "../assets/diego-comic.png";
import diegoLego from "../assets/diego-lego.png";
import diegoCartoon from "../assets/diego-cartoon.png";
import Icon from "./Icon.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const yearsOfExperience = yearsSince(personal.careerStartDate);
const tagline = {
  en: personal.tagline.en.replace("{years}", String(yearsOfExperience)),
  es: personal.tagline.es.replace("{years}", String(yearsOfExperience)),
};

const photoVariants = [
  { src: diegoPhoto, styleKey: "hero.photoStyleReal" },
  { src: diegoComic, styleKey: "hero.photoStyleComic" },
  { src: diegoLego, styleKey: "hero.photoStyleLego" },
  { src: diegoCartoon, styleKey: "hero.photoStyleCartoon" },
] as const;
---

<section class="hero" id="top">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-grid">
      <!-- Text column -->
      <div class="hero-text">
        <div
          class="hero-greeting font-mono hero-anim"
          style="animation-delay:0.15s"
        >
          <span class="greeting-dot" aria-hidden="true"></span>
          <span {...i18nText("hero.greeting")}>{t("hero.greeting", lang)}</span>
        </div>

        <h1 class="hero-name hero-anim" style="animation-delay:0.3s">
          {personal.name}
        </h1>

        <p
          class="hero-role hero-anim"
          style="animation-delay:0.42s"
          {...i18nTextLoc(personal.role)}
        >
          {personal.role[lang]}
        </p>

        <p class="hero-location hero-anim" style="animation-delay:0.5s">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
            ></path><circle cx="12" cy="10" r="3"></circle></svg
          >
          {personal.location}
        </p>

        <p
          class="hero-tagline hero-anim"
          style="animation-delay:0.6s"
          {...i18nTextLoc(tagline)}
        >
          {tagline[lang]}
        </p>

        <div class="hero-actions hero-anim" style="animation-delay:0.72s">
          <a
            href={personal.linkedin}
            target="_blank"
            rel="noopener"
            class="btn btn-secondary"
            aria-label={t("contact.linkedinLabel", lang)}
            {...i18nAttr("aria-label", "contact.linkedinLabel")}
          >
            <Icon name="linkedin" size={16} />
            <span {...i18nText("contact.linkedinLabel")}>
              {t("contact.linkedinLabel", lang)}
            </span>
          </a>
          <a
            href={personal.github}
            target="_blank"
            rel="noopener"
            class="btn btn-secondary"
            aria-label={t("contact.githubLabel", lang)}
            {...i18nAttr("aria-label", "contact.githubLabel")}
          >
            <Icon name="github" size={16} />
            <span {...i18nText("hero.ctaGithub")}
              >{t("hero.ctaGithub", lang)}</span
            >
          </a>
          <a
            href={personal.credly}
            target="_blank"
            rel="noopener"
            class="btn btn-secondary"
            aria-label={t("contact.credlyLabel", lang)}
            {...i18nAttr("aria-label", "contact.credlyLabel")}
          >
            <Icon name="award" size={16} />
            <span {...i18nText("contact.credlyLabel")}>
              {t("contact.credlyLabel", lang)}
            </span>
          </a>
          <a href={`mailto:${personal.email}`} class="btn btn-primary">
            <Icon name="mail" size={16} />
            <span {...i18nText("hero.ctaContact")}
              >{t("hero.ctaContact", lang)}</span
            >
          </a>
        </div>
      </div>

      <!-- Visual column -->
      <div class="hero-visual hero-anim" style="animation-delay:0.45s">
        <div class="hero-photo-wrap">
          <span class="hero-glow" aria-hidden="true"></span>
          <span class="hero-dots" aria-hidden="true"></span>
          <div class="hero-photo-blob" aria-hidden="true"></div>
          <button
            type="button"
            id="hero-photo-btn"
            class="hero-photo-frame"
            aria-label={t("hero.photoHint", lang)}
            {...i18nAttr("aria-label", "hero.photoHint")}
          >
            <div class="hero-photo-flip" id="hero-photo-flip">
              {
                photoVariants.map((variant, i) => (
                  <Image
                    src={variant.src}
                    alt={`${personal.name} — ${t(variant.styleKey, lang)}`}
                    class={`hero-photo${i === 0 ? " is-active" : ""}`}
                    widths={[280, 420, 560]}
                    sizes="(max-width: 900px) 280px, 420px"
                    format="webp"
                    quality={82}
                    loading={i === 0 ? "eager" : "lazy"}
                  />
                ))
              }
            </div>
            <span class="hero-photo-hint" aria-hidden="true">
              <Icon name="shuffle" size={14} />
            </span>
          </button>
          <svg
            width="0"
            height="0"
            aria-hidden="true"
            style="position:absolute"
          >
            <defs>
              <clipPath id="heroBlob" clipPathUnits="objectBoundingBox">
                <path
                  d="M0.05,0.38 C0.0,0.55 0.02,0.78 0.1,0.92 C0.22,1.04 0.48,0.98 0.65,1.0 C0.82,1.02 0.98,0.9 1.0,0.7 C1.02,0.5 0.96,0.34 0.85,0.26 C0.72,0.18 0.55,0.22 0.4,0.25 C0.22,0.29 0.1,0.24 0.05,0.38 Z"
                ></path>
              </clipPath>
            </defs>
          </svg>
          <div class="hero-card">
            <span class="hero-card-icon" aria-hidden="true">
              <Icon name="code" size={18} />
            </span>
            <span {...i18nText("hero.impact")}>{t("hero.impact", lang)}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 75% 40%,
      var(--color-glow) 0%,
      transparent 65%
    );
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  /* ===== Text column ===== */
  .hero-greeting {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg-card);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 500;
    margin-bottom: 1.35rem;
  }
  .greeting-dot {
    position: relative;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent-light);
  }
  .greeting-dot::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: inherit;
    animation: greetingPing 2.4s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  @keyframes greetingPing {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    70%,
    100% {
      transform: scale(2.6);
      opacity: 0;
    }
  }
  .hero-name {
    font-size: clamp(2.4rem, 5.5vw, 4.25rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 0.85rem;
  }
  .hero-role {
    font-size: clamp(1.15rem, 2.5vw, 1.6rem);
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 1.35rem;
  }
  .hero-location {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    opacity: 0.85;
  }
  .hero-tagline {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 46ch;
    margin-bottom: 2rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.6rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 0.3s,
      box-shadow 0.3s,
      border-color 0.3s;
  }
  .btn :global(svg) {
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .btn:hover :global(svg) {
    transform: scale(1.15);
  }
  .btn-primary {
    background: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px var(--color-glow);
  }
  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-secondary:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  /* ===== Visual column ===== */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .hero-photo-wrap {
    position: relative;
    width: min(100%, 360px);
    opacity: 0;
    transform: translateY(24px);
    animation: heroPhotoIn 0.7s ease-out 0.5s forwards;
  }
  @keyframes heroPhotoIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .hero-glow {
    position: absolute;
    top: 5%;
    left: -12%;
    width: 124%;
    height: 85%;
    background: radial-gradient(
      ellipse at 50% 45%,
      var(--color-accent) 0%,
      var(--color-accent-light) 30%,
      transparent 70%
    );
    filter: blur(55px);
    opacity: 0.2;
    z-index: 0;
    border-radius: 50%;
    animation: glowBreathe 9s ease-in-out infinite;
  }
  @keyframes glowBreathe {
    0%,
    100% {
      opacity: 0.18;
      transform: scale(1);
    }
    50% {
      opacity: 0.28;
      transform: scale(1.06);
    }
  }
  .hero-dots {
    position: absolute;
    top: -1rem;
    right: -0.5rem;
    width: 110px;
    height: 110px;
    background-image: radial-gradient(
      var(--color-accent) 1.4px,
      transparent 1.4px
    );
    background-size: 14px 14px;
    opacity: 0.25;
    z-index: 3;
    -webkit-mask-image: linear-gradient(225deg, #000 25%, transparent 75%);
    mask-image: linear-gradient(225deg, #000 25%, transparent 75%);
  }
  .hero-photo-blob {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      155deg,
      var(--color-accent) 0%,
      var(--color-accent-light) 45%,
      var(--color-accent-lighter) 100%
    );
    clip-path: url(#heroBlob);
    filter: drop-shadow(0 18px 28px var(--color-glow));
    transition: filter 0.4s;
  }
  .hero-photo-frame {
    appearance: none;
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    text-align: inherit;
    cursor: pointer;
    position: relative;
    z-index: 2;
    perspective: 1200px;
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.45s;
  }
  .hero-photo-frame:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 6px;
    border-radius: 4%;
  }
  .hero-photo-wrap:hover .hero-photo-frame {
    transform: translateY(-8px);
    filter: brightness(1.04);
  }
  .hero-photo-wrap:hover .hero-photo-blob {
    filter: drop-shadow(0 28px 42px var(--color-glow));
  }
  .hero-photo-flip {
    position: relative;
    width: 100%;
    display: grid;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-photo {
    display: block;
    grid-area: 1 / 1;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 15%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 4%,
      #000 100%
    );
    mask-image: linear-gradient(to bottom, transparent 0%, #000 4%, #000 100%);
  }
  .hero-photo.is-active {
    opacity: 1;
  }
  .hero-photo-hint {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-bg);
    box-shadow: 0 8px 20px -6px var(--color-glow);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-photo-wrap:hover .hero-photo-hint {
    transform: scale(1.12) rotate(15deg);
  }
  .hero-card {
    position: absolute;
    left: -0.5rem;
    bottom: 1.5rem;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    max-width: 215px;
    padding: 0.75rem 0.95rem;
    border-radius: 14px;
    background: var(--color-nav-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 45px -22px rgba(0, 0, 0, 0.5);
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-text);
    animation: cardFloat 6s ease-in-out 1.5s infinite;
  }
  @keyframes cardFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-7px);
    }
  }
  .hero-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--color-accent);
    color: var(--color-bg);
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      justify-items: start;
    }
    .hero-visual {
      order: -1;
      justify-content: flex-start;
    }
    .hero-photo-wrap {
      width: min(60%, 250px);
    }
    .hero-tagline {
      max-width: none;
    }
  }

  @media (max-width: 480px) {
    .hero-card {
      left: -0.25rem;
      max-width: 185px;
      font-size: 0.74rem;
      padding: 0.6rem 0.75rem;
    }
    .hero-dots {
      width: 80px;
      height: 80px;
    }
    .hero-photo-wrap {
      width: min(55%, 220px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-photo-wrap {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .greeting-dot::after,
    .hero-glow,
    .hero-card {
      animation: none;
    }
    .btn :global(svg) {
      transition: none;
    }
    .btn:hover :global(svg) {
      transform: none;
    }
    .hero-photo-flip {
      transition: none;
    }
    .hero-photo {
      transition: none;
    }
  }
</style>

<script>
  const btn = document.getElementById("hero-photo-btn");
  const flip = document.getElementById("hero-photo-flip");
  const photos = flip
    ? Array.from(flip.querySelectorAll<HTMLElement>(".hero-photo"))
    : [];
  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  let index = 0;
  let animating = false;

  btn?.addEventListener("click", () => {
    if (!flip || animating || photos.length < 2) return;
    const next = (index + 1) % photos.length;

    if (reduceMotion) {
      photos[index].classList.remove("is-active");
      photos[next].classList.add("is-active");
      index = next;
      return;
    }

    animating = true;
    flip.style.transform = "rotateY(90deg) scale(0.88)";
    setTimeout(() => {
      photos[index].classList.remove("is-active");
      photos[next].classList.add("is-active");
      index = next;
      flip.style.transform = "rotateY(0deg) scale(1)";
      setTimeout(() => {
        animating = false;
      }, 600);
    }, 300);
  });
</script>
