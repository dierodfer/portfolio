---
import type { Lang } from "../i18n/i18n";
import { t, i18nText, i18nTextLoc, i18nAttr } from "../i18n/i18n";
import { personal } from "../data/personal";
import { Image } from "astro:assets";
import diegoPhoto from "../assets/diego.png";
import Icon from "./Icon.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="hero" id="top">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-grid">
      <!-- Text column -->
      <div class="hero-text">
        <div
          class="hero-greeting font-mono hero-anim"
          style="animation-delay:0.15s"
        >
          <span class="greeting-dot" aria-hidden="true"></span>
          <span {...i18nText("hero.greeting")}>{t("hero.greeting", lang)}</span>
        </div>

        <h1 class="hero-name hero-anim" style="animation-delay:0.3s">
          {personal.name}
        </h1>

        <p
          class="hero-role hero-anim"
          style="animation-delay:0.42s"
          {...i18nTextLoc(personal.role)}
        >
          {personal.role[lang]}
        </p>

        <p
          class="hero-tagline hero-anim"
          style="animation-delay:0.54s"
          {...i18nTextLoc(personal.tagline)}
        >
          {personal.tagline[lang]}
        </p>

        <div class="hero-actions hero-anim" style="animation-delay:0.66s">
          <a href={`mailto:${personal.email}`} class="btn btn-primary">
            <Icon name="mail" size={16} />
            <span {...i18nText("hero.ctaContact")}
              >{t("hero.ctaContact", lang)}</span
            >
          </a>
          <a
            href={personal.github}
            target="_blank"
            rel="noopener"
            class="btn btn-secondary"
            aria-label={t("contact.githubLabel", lang)}
            {...i18nAttr("aria-label", "contact.githubLabel")}
          >
            <Icon name="github" size={16} />
            <span {...i18nText("hero.ctaGithub")}
              >{t("hero.ctaGithub", lang)}</span
            >
          </a>
          <a
            href={personal.linkedin}
            target="_blank"
            rel="noopener"
            class="btn btn-secondary"
            aria-label={t("contact.linkedinLabel", lang)}
            {...i18nAttr("aria-label", "contact.linkedinLabel")}
          >
            <Icon name="linkedin" size={16} />
            <span {...i18nText("contact.linkedinLabel")}>
              {t("contact.linkedinLabel", lang)}
            </span>
          </a>
        </div>
      </div>

      <!-- Visual column -->
      <div class="hero-visual hero-anim" style="animation-delay:0.45s">
        <div class="hero-photo-wrap" id="hero-photo-wrap">
          <span class="hero-glow" aria-hidden="true"></span>
          <span class="hero-dots" aria-hidden="true"></span>
          <div class="hero-photo-blob" aria-hidden="true"></div>
          <div class="hero-photo-frame">
            <Image
              src={diegoPhoto}
              alt={personal.name}
              class="hero-photo"
              widths={[280, 420, 560]}
              sizes="(max-width: 900px) 280px, 420px"
              format="webp"
              quality={82}
              loading="eager"
            />
          </div>
          <svg
            width="0"
            height="0"
            aria-hidden="true"
            style="position:absolute"
          >
            <defs>
              <clipPath id="heroBlob" clipPathUnits="objectBoundingBox">
                <path
                  d="M0.05,0.38 C0.0,0.55 0.02,0.78 0.1,0.92 C0.22,1.04 0.48,0.98 0.65,1.0 C0.82,1.02 0.98,0.9 1.0,0.7 C1.02,0.5 0.96,0.34 0.85,0.26 C0.72,0.18 0.55,0.22 0.4,0.25 C0.22,0.29 0.1,0.24 0.05,0.38 Z"
                ></path>
              </clipPath>
            </defs>
          </svg>
          <div class="hero-card">
            <span class="hero-card-icon" aria-hidden="true">
              <Icon name="code" size={18} />
            </span>
            <span {...i18nText("hero.impact")}>{t("hero.impact", lang)}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 75% 40%,
      var(--color-glow) 0%,
      transparent 65%
    );
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  /* ===== Text column ===== */
  .hero-greeting {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg-card);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 500;
    margin-bottom: 1.35rem;
  }
  .greeting-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent-light);
  }
  .hero-name {
    font-size: clamp(2.4rem, 5.5vw, 4.25rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 0.85rem;
  }
  .hero-role {
    font-size: clamp(1.15rem, 2.5vw, 1.6rem);
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 1.35rem;
  }
  .hero-tagline {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 46ch;
    margin-bottom: 2rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.6rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 0.3s,
      box-shadow 0.3s,
      border-color 0.3s;
  }
  .btn-primary {
    background: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px var(--color-glow);
  }
  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-secondary:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  /* ===== Visual column ===== */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .hero-photo-wrap {
    position: relative;
    width: min(100%, 360px);
    opacity: 0;
    transform: scale(0.5) translateY(70px) rotate(-10deg);
    animation: heroPhotoIn 1.15s ease-out 0.45s forwards;
  }
  @keyframes heroPhotoIn {
    0% {
      opacity: 0;
      transform: scale(0.5) translateY(70px) rotate(-10deg);
    }
    55% {
      opacity: 1;
      transform: scale(1.08) translateY(-10px) rotate(4deg);
    }
    78% {
      transform: scale(0.96) translateY(0) rotate(-2deg);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0) rotate(0);
    }
  }
  .hero-glow {
    position: absolute;
    top: 5%;
    left: -12%;
    width: 124%;
    height: 85%;
    background: radial-gradient(
      ellipse at 50% 45%,
      var(--color-accent) 0%,
      var(--color-accent-light) 30%,
      transparent 70%
    );
    filter: blur(55px);
    opacity: 0.2;
    z-index: 0;
    border-radius: 50%;
  }
  .hero-dots {
    position: absolute;
    top: -1rem;
    right: -0.5rem;
    width: 110px;
    height: 110px;
    background-image: radial-gradient(
      var(--color-accent) 1.4px,
      transparent 1.4px
    );
    background-size: 14px 14px;
    opacity: 0.25;
    z-index: 3;
    -webkit-mask-image: linear-gradient(225deg, #000 25%, transparent 75%);
    mask-image: linear-gradient(225deg, #000 25%, transparent 75%);
  }
  .hero-photo-blob {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      155deg,
      var(--color-accent) 0%,
      var(--color-accent-light) 45%,
      var(--color-accent-lighter) 100%
    );
    clip-path: url(#heroBlob);
    filter: drop-shadow(0 18px 28px var(--color-glow));
    transition: filter 0.4s;
  }
  .hero-photo-frame {
    position: relative;
    z-index: 2;
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-photo-frame:hover {
    transform: translateY(-6px) scale(1.02);
  }
  .hero-photo-wrap:hover .hero-photo-blob {
    filter: drop-shadow(0 26px 38px var(--color-glow));
  }
  .hero-photo-frame.is-pop {
    animation: heroPhotoPop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes heroPhotoPop {
    0% {
      transform: scale(1) rotate(0);
    }
    25% {
      transform: scale(1.09) rotate(-3deg);
    }
    50% {
      transform: scale(0.93) rotate(2.5deg);
    }
    75% {
      transform: scale(1.04) rotate(-1deg);
    }
    100% {
      transform: scale(1) rotate(0);
    }
  }
  .hero-photo {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 15%;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 4%,
      #000 100%
    );
    mask-image: linear-gradient(to bottom, transparent 0%, #000 4%, #000 100%);
  }
  .hero-card {
    position: absolute;
    left: -0.5rem;
    bottom: 1.5rem;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    max-width: 215px;
    padding: 0.75rem 0.95rem;
    border-radius: 14px;
    background: var(--color-nav-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 45px -22px rgba(0, 0, 0, 0.5);
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-text);
  }
  .hero-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--color-accent);
    color: var(--color-bg);
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.75rem;
      justify-items: start;
    }
    .hero-visual {
      order: -1;
      justify-content: flex-start;
    }
    .hero-photo-wrap {
      width: min(70%, 290px);
    }
    .hero-tagline {
      max-width: none;
    }
  }

  @media (max-width: 480px) {
    .hero-card {
      left: -0.25rem;
      max-width: 185px;
      font-size: 0.74rem;
      padding: 0.6rem 0.75rem;
    }
    .hero-dots {
      width: 80px;
      height: 80px;
    }
    .hero-photo-wrap {
      width: min(65%, 260px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-photo-wrap {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-photo-frame.is-pop {
      animation: none;
    }
  }
</style>

<script>
  const wrap = document.getElementById("hero-photo-wrap");
  const frame = wrap?.querySelector<HTMLElement>(".hero-photo-frame");
  frame?.addEventListener("click", () => {
    frame.classList.remove("is-pop");
    void frame.offsetWidth;
    frame.classList.add("is-pop");
  });
  frame?.addEventListener("animationend", () => {
    frame.classList.remove("is-pop");
  });
</script>
