---
import type { Lang } from "../i18n/i18n";
import { t } from "../i18n/i18n";
import { technologies } from "../data/technologies";
import { projects } from "../data/projects";
import { experience } from "../data/experience";
import { withBase } from "../lib/paths";
import Section from "./Section.astro";
import Icon from "./Icon.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

function relatedFor(id: string) {
  const projs = projects.filter(
    (p) => p.technologies.includes(id) || p.platforms?.includes(id),
  );
  const exps = experience.filter((e) =>
    e.roles.some((r) => r.technologies.includes(id)),
  );
  return { projs, exps };
}
---

<Section
  id="tecnologias"
  tag={t("sections.technologiesTag", lang)}
  title={t("sections.technologiesTitle", lang)}
  hint={t("sections.technologiesHint", lang)}
>
  <div class="tech-grid">
    {
      technologies.map((cat, i) => (
        <div
          class="tech-category animate-on-scroll"
          class:list={[`stagger-${(i % 7) + 1}`]}
        >
          <h3 class="tech-cat-title font-mono">{cat.name[lang]}</h3>
          <div class="tech-items">
            {cat.items.map((item) => {
              const { projs, exps } = relatedFor(item.id);
              const count = projs.length + exps.length;
              const linked = count > 0;
              return (
                <div class="skill" class:list={[linked && "is-linked"]}>
                  <button
                    type="button"
                    class="skill-chip"
                    data-skill={item.id}
                    title={item.name}
                    aria-label={item.name}
                    aria-haspopup={linked ? "true" : undefined}
                    aria-expanded={linked ? "false" : undefined}
                    disabled={!linked}
                  >
                    <img
                      src={withBase(`icons/tech/${item.icon}`)}
                      alt={item.name}
                      width="40"
                      height="40"
                      loading="lazy"
                    />
                    {linked && <span class="skill-dot" aria-hidden="true" />}
                  </button>

                  {linked && (
                    <div class="skill-pop" role="menu" aria-label={item.name}>
                      <div class="pop-head">
                        <img
                          class="pop-head-icon"
                          src={withBase(`icons/tech/${item.icon}`)}
                          alt=""
                          width="22"
                          height="22"
                        />
                        <span class="pop-head-name">{item.name}</span>
                        <span class="pop-count">{count}</span>
                      </div>
                      <div class="pop-list">
                        {projs.map((p) => (
                          <a
                            class="pop-item"
                            href={`#project-${p.id}`}
                            role="menuitem"
                          >
                            <span class="pop-ico">
                              {p.icon ? (
                                <img
                                  src={withBase(`icons/projects/${p.icon}`)}
                                  alt=""
                                  width="28"
                                  height="28"
                                />
                              ) : (
                                <Icon name="grid" size={18} />
                              )}
                            </span>
                            <span class="pop-text">
                              <span class="pop-title">{p.title[lang]}</span>
                              <span class="pop-meta">
                                {t("skills.project", lang)}
                              </span>
                            </span>
                            <span class="pop-arrow" aria-hidden="true">
                              →
                            </span>
                          </a>
                        ))}
                        {exps.map((e) => {
                          const matchingRole = e.roles.find((r) =>
                            r.technologies.includes(item.id),
                          );
                          return (
                            <a
                              class="pop-item"
                              href={`#exp-${e.id}`}
                              role="menuitem"
                            >
                              <span class="pop-ico">
                                <Icon name="briefcase" size={18} />
                              </span>
                              <span class="pop-text">
                                <span class="pop-title">{e.company}</span>
                                <span class="pop-meta">
                                  {matchingRole?.role[lang]}
                                </span>
                              </span>
                              <span class="pop-arrow" aria-hidden="true">
                                →
                              </span>
                            </a>
                          );
                        })}
                      </div>
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      ))
    }
  </div>
</Section>

<style>
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    overflow: visible;
  }
  .tech-category {
    overflow: visible;
  }
  .tech-category.visible {
    transform: none;
  }
  .tech-cat-title {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }
  .tech-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skill {
    position: relative;
  }
  .skill.open {
    z-index: 40;
  }
  .skill-chip {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    padding: 8px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    transition:
      transform 0.3s,
      border-color 0.3s,
      box-shadow 0.3s;
  }
  .skill.is-linked .skill-chip {
    cursor: pointer;
  }
  .skill.is-linked .skill-chip:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent-light);
    box-shadow: 0 10px 24px -12px var(--color-glow);
  }
  .skill.open .skill-chip {
    border-color: var(--color-accent-light);
    box-shadow: 0 0 0 3px var(--color-glow);
  }
  .skill:not(.is-linked) .skill-chip {
    opacity: 0.55;
  }
  .skill-chip img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }
  .skill-dot {
    position: absolute;
    top: 7px;
    right: 7px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent-light);
    opacity: 0.55;
    transition:
      opacity 0.3s,
      transform 0.3s;
  }
  .skill.is-linked .skill-chip:hover .skill-dot,
  .skill.open .skill-dot {
    opacity: 1;
    transform: scale(1.2);
  }

  .skill-pop {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    width: 280px;
    max-width: min(280px, 78vw);
    padding: 0.5rem;
    border-radius: 14px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    box-shadow: 0 24px 60px -18px rgba(0, 0, 0, 0.45);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px) scale(0.97);
    transform-origin: top left;
    pointer-events: none;
    transition:
      opacity 0.22s ease,
      transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0.22s;
    z-index: 41;
  }
  .skill.open .skill-pop {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .skill.open.flip-right .skill-pop {
    left: auto;
    right: 0;
    transform-origin: top right;
  }

  .pop-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.55rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.35rem;
  }
  .pop-head-icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }
  .pop-head-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .pop-count {
    margin-left: auto;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.05rem 0.45rem;
  }

  .pop-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    max-height: 320px;
    overflow-y: auto;
  }
  .pop-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem;
    border-radius: 10px;
    color: var(--color-text);
    transition: background 0.2s;
  }
  .pop-item:hover {
    background: var(--color-bg-card);
  }
  .pop-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-accent);
    overflow: hidden;
  }
  .pop-ico img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }
  .pop-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .pop-title {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pop-meta {
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pop-arrow {
    margin-left: auto;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.2s,
      transform 0.2s;
  }
  .pop-item:hover .pop-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 1024px) {
    .tech-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .tech-grid {
      grid-template-columns: 1fr;
    }
    .skill-pop {
      width: 260px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-pop {
      transition:
        opacity 0.01s,
        visibility 0.01s;
      transform: none;
    }
    .skill.open .skill-pop {
      transform: none;
    }
  }
</style>
