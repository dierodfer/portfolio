---
import type { Lang, TranslationKey } from "../i18n/i18n";
import { t, i18nText } from "../i18n/i18n";

interface Props {
  id: string;
  lang: Lang;
  tagKey: TranslationKey;
  titleKey: TranslationKey;
  hintKey?: TranslationKey;
  narrow?: boolean;
}

const { id, lang, tagKey, titleKey, hintKey, narrow = false } = Astro.props;
---

<section {id} class="section">
  <div
    class:list={["section-container", narrow && "section-container--narrow"]}
  >
    <p class="section-tag font-mono animate-on-scroll" {...i18nText(tagKey)}>
      {t(tagKey, lang)}
    </p>
    <h2 class="section-heading animate-on-scroll" {...i18nText(titleKey)}>
      {t(titleKey, lang)}
    </h2>
    {
      hintKey && (
        <p class="section-hint animate-on-scroll" {...i18nText(hintKey)}>
          {t(hintKey, lang)}
        </p>
      )
    }
    <slot />
  </div>
</section>

<style>
  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .section-container--narrow {
    max-width: 820px;
  }
  .section-tag {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .section-heading {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
  }
  .section-hint {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-top: -2.25rem;
    margin-bottom: 3rem;
  }
</style>
