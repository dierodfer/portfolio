---
// Thin reading-progress bar fixed to the top of the viewport.
---

<div id="scroll-progress" class="scroll-progress"></div>

<style>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    z-index: 60;
    background: linear-gradient(
      90deg,
      var(--color-accent),
      var(--color-accent-light)
    );
    box-shadow: 0 0 8px var(--color-glow);
    transition: width 0.1s linear;
  }
</style>

<script>
  const bar = document.getElementById("scroll-progress");
  // <main> is the scroll container, so read progress from it (not the document).
  const scroller = document.querySelector("main");
  let ticking = false;
  const update = () => {
    if (!bar || !scroller) return;
    const top = scroller.scrollTop;
    const height = scroller.scrollHeight - scroller.clientHeight;
    const pct = height > 0 ? (top / height) * 100 : 0;
    bar.style.width = pct + "%";
    ticking = false;
  };
  const onScroll = () => {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(update);
    }
  };
  scroller?.addEventListener("scroll", onScroll, { passive: true });
  update();
</script>
