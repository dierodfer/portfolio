---
import type { Lang } from "../i18n/i18n";
import { t } from "../i18n/i18n";
import type { Project } from "../data/projects";
import TechIcon from "./TechIcon.astro";
import { withBase } from "../lib/paths";

interface Props {
  project: Project;
  lang: Lang;
  stagger: number;
}

const { project, lang, stagger } = Astro.props;
const hasIcon = !!project.icon;
const hasPlatforms = !!project.platforms?.length;
const hasLive = !!project.liveUrl;
const hasGithub = !!project.githubUrl;
---

<article
  id={`project-${project.id}`}
  class:list={["project-card", "flashable", "animate-on-scroll", `stagger-${stagger}`]}
>
  {hasIcon && (
    <img
      src={withBase(`icons/projects/${project.icon}`)}
      alt=""
      class="card-bg-icon"
      aria-hidden="true"
      loading="lazy"
    />
  )}

  <div class="card-body">
    <h3 class="card-title">{project.title[lang]}</h3>
    <p class="card-desc">{project.description[lang]}</p>
    <div class="card-tech">
      {project.technologies.map((id) => <TechIcon id={id} size={20} mini />)}
    </div>
    {hasPlatforms && (
      <div class="card-platforms">
        {project.platforms!.map((id) => <TechIcon id={id} size={16} />)}
      </div>
    )}
  </div>

  <div class="card-actions">
    {hasLive && (
      <a href={project.liveUrl} target="_blank" rel="noopener" class="card-btn card-btn-primary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          <polyline points="15 3 21 3 21 9" />
          <line x1="10" y1="14" x2="21" y2="3" />
        </svg>
        <span>{t("projects.liveDemo", lang)}</span>
      </a>
    )}
    {hasGithub && (
      <a href={project.githubUrl} target="_blank" rel="noopener" class="card-btn card-btn-secondary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span>{t("projects.sourceCode", lang)}</span>
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 240px;
    padding: 1.75rem;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.4s,
      box-shadow 0.4s;
  }
  .project-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-glow) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
  }
  .project-card:hover::before { opacity: 1; }
  .project-card:hover {
    border-color: var(--color-accent-light);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px -15px var(--color-glow);
  }

  /* ===== Lateral background watermark icon ===== */
  .card-bg-icon {
    position: absolute;
    right: -10%;
    top: 42%;
    transform: translateY(-50%) rotate(-6deg);
    width: 62%;
    max-width: 190px;
    height: auto;
    object-fit: contain;
    opacity: 0.16;
    pointer-events: none;
    z-index: 0;
    filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.25));
    transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    -webkit-mask-image: linear-gradient(to left, #000 55%, transparent 100%);
    mask-image: linear-gradient(to left, #000 55%, transparent 100%);
  }
  .project-card:hover .card-bg-icon {
    opacity: 0.3;
    transform: translateY(-50%) rotate(-3deg) scale(1.05);
  }

  /* ===== Card body ===== */
  .card-body {
    margin-top: auto;
    position: relative;
    z-index: 1;
  }
  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    transition: color 0.3s;
  }
  .project-card:hover .card-title { color: var(--color-accent-lighter); }

  .card-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    max-width: 90%;
  }
  .card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }
  .card-platforms {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-top: 0.6rem;
    padding: 0.25rem 0.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    width: fit-content;
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  .project-card:hover .card-platforms { opacity: 1; }

  /* ===== Action buttons ===== */
  .card-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.15rem;
    position: relative;
    z-index: 2;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s, transform 0.3s;
  }
  .project-card:hover .card-actions {
    opacity: 1;
    transform: translateY(0);
  }

  .card-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, box-shadow 0.2s;
    white-space: nowrap;
  }

  .card-btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }
  .card-btn-primary:hover {
    background: var(--color-accent-light);
    box-shadow: 0 4px 14px -4px var(--color-glow);
  }

  .card-btn-secondary {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }
  .card-btn-secondary:hover {
    color: var(--color-text);
    border-color: var(--color-accent-light);
    background: var(--color-bg-alt);
  }

  @media (max-width: 768px) {
    .project-card { min-height: 200px; }
    .card-bg-icon { opacity: 0.14; }
    .card-actions { opacity: 1; transform: none; }
  }
</style>
