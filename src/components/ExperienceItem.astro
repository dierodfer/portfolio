---
import type { Lang } from "../i18n/i18n";
import { i18nTextLoc } from "../i18n/i18n";
import type { ExperienceEntry, ExperienceRole } from "../data/experience";
import type { Localized } from "../data/personal";
import TechIcon from "./TechIcon.astro";
import Icon from "./Icon.astro";
import { withBase } from "../lib/paths";

interface Props {
  entry: ExperienceEntry;
  lang: Lang;
  stagger: number;
}

const { entry, lang, stagger } = Astro.props;

/** Work-mode keywords that earn a monitor icon (EN side drives detection). */
const MODE_WORDS = new Set([
  "Remote",
  "Hybrid",
  "On-site",
  "Onsite",
  "Remoto",
  "Híbrido",
  "Presencial",
]);

const EM_DASH = "—";

/** Split a localized period into a big start year + a small localized suffix. */
function parsePeriod(period: Localized) {
  const year = period.en.split(EM_DASH)[0].trim();
  const suffix: Localized = {
    en: `${EM_DASH} ${period.en.split(EM_DASH).slice(1).join(EM_DASH).trim()}`,
    es: `${EM_DASH} ${period.es.split(EM_DASH).slice(1).join(EM_DASH).trim()}`,
  };
  return { year, suffix };
}

/** Split a localized location into place + optional tail (work-mode or country). */
function parseLocation(loc: Localized) {
  const enParts = loc.en.split("·");
  const esParts = loc.es.split("·");
  const place: Localized = { en: enParts[0].trim(), es: esParts[0].trim() };
  const tailEn = enParts[1]?.trim();
  if (!tailEn) return { place, tail: null as Localized | null, isMode: false };
  const tail: Localized = { en: tailEn, es: (esParts[1] ?? "").trim() };
  return { place, tail, isMode: MODE_WORDS.has(tailEn) };
}

const primary = entry.roles[0];
const extraRoles = entry.roles.slice(1);
const { year, suffix } = parsePeriod(primary.period);
---

<div class:list={["timeline-item", "animate-on-scroll", `stagger-${stagger}`]}>
  <div class="exp-rail">
    <span class="exp-year">{year}</span>
    <span class="exp-year-suffix" {...i18nTextLoc(suffix)}>{suffix[lang]}</span>
  </div>

  <div class="exp-marker" aria-hidden="true"><span class="exp-dot"></span></div>

  <article id={`exp-${entry.id}`} class="exp-card flashable">
    <header class="exp-header">
      <div class="exp-logo">
        <img
          src={withBase(`icons/companies/${entry.logo}`)}
          alt={entry.company}
          loading="lazy"
        />
      </div>
      <div class="exp-headings">
        <h3 class="exp-company">{entry.company}</h3>
        <p class="exp-role">
          <span class="role" {...i18nTextLoc(primary.role)}
            >{primary.role[lang]}</span
          >
          {
            primary.client && (
              <>
                <span class="exp-sep">|</span>
                <span class="exp-client">{primary.client}</span>
              </>
            )
          }
        </p>
        {
          (() => {
            const { place, tail, isMode } = parseLocation(primary.location);
            return (
              <p class="exp-meta">
                <span class="exp-meta-item">
                  <Icon name="pin" size={14} />
                  <span {...i18nTextLoc(place)}>{place[lang]}</span>
                </span>
                {tail && (
                  <span class="exp-meta-item">
                    <span class="exp-meta-dot">·</span>
                    {isMode && <Icon name="monitor" size={14} />}
                    <span {...i18nTextLoc(tail)}>{tail[lang]}</span>
                  </span>
                )}
              </p>
            );
          })()
        }
      </div>
    </header>

    <div class="exp-divider"></div>

    <ul class:list={["exp-desc", `bullet-${entry.bullet}`]}>
      {primary.description.map((d) => <li {...i18nTextLoc(d)}>{d[lang]}</li>)}
    </ul>

    <div class="exp-tech">
      {
        primary.technologies.map((id) => (
          <span class="exp-chip">
            <TechIcon id={id} size={22} />
          </span>
        ))
      }
    </div>

    {
      extraRoles.map((role: ExperienceRole) => {
        const sub = parsePeriod(role.period);
        const subLoc = parseLocation(role.location);
        return (
          <div class="exp-subrole">
            <p class="exp-role">
              <span class="role" {...i18nTextLoc(role.role)}>
                {role.role[lang]}
              </span>
              {role.client && (
                <>
                  <span class="exp-sep">|</span>
                  <span class="exp-client">{role.client}</span>
                </>
              )}
              <span class="exp-subperiod font-mono">
                {sub.year}{" "}
                <span {...i18nTextLoc(sub.suffix)}>{sub.suffix[lang]}</span>
              </span>
            </p>
            <p class="exp-meta">
              <span class="exp-meta-item">
                <Icon name="pin" size={14} />
                <span {...i18nTextLoc(subLoc.place)}>{subLoc.place[lang]}</span>
              </span>
              {subLoc.tail && (
                <span class="exp-meta-item">
                  <span class="exp-meta-dot">·</span>
                  {subLoc.isMode && <Icon name="monitor" size={14} />}
                  <span {...i18nTextLoc(subLoc.tail)}>{subLoc.tail[lang]}</span>
                </span>
              )}
            </p>
            <ul class:list={["exp-desc", `bullet-${entry.bullet}`]}>
              {role.description.map((d) => (
                <li {...i18nTextLoc(d)}>{d[lang]}</li>
              ))}
            </ul>
            <div class="exp-tech">
              {role.technologies.map((id) => (
                <span class="exp-chip">
                  <TechIcon id={id} size={22} />
                </span>
              ))}
            </div>
          </div>
        );
      })
    }
  </article>
</div>

<style>
  .timeline-item {
    display: grid;
    grid-template-columns: 3.25rem 1.5rem 1fr;
    column-gap: 0.85rem;
    padding-bottom: 2.25rem;
  }

  /* ===== Left rail: start year ===== */
  .exp-rail {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    padding-top: 0.35rem;
    line-height: 1.1;
  }
  .exp-year {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
  }
  .exp-year-suffix {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    margin-top: 0.15rem;
    white-space: nowrap;
  }

  /* ===== Middle marker: dot + connecting line ===== */
  .exp-marker {
    position: relative;
  }
  .exp-marker::before {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0.9rem;
    bottom: -2.25rem;
    width: 2px;
    background: linear-gradient(var(--color-border) 60%, transparent);
    background-size: 2px 8px;
  }
  .timeline-item:last-child .exp-marker::before {
    display: none;
  }
  .exp-dot {
    position: absolute;
    left: 50%;
    top: 0.6rem;
    transform: translateX(-50%);
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 3px var(--color-glow);
    z-index: 1;
  }

  /* ===== Card (shares the project-card visual language) ===== */
  .exp-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem 1.65rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.4s,
      box-shadow 0.4s;
  }
  .exp-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-glow) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
  }
  .exp-card:hover::before {
    opacity: 1;
  }
  .exp-card:hover {
    border-color: var(--color-accent-light);
    transform: translateY(-3px);
    box-shadow: 0 18px 50px -18px var(--color-glow);
  }

  /* ===== Header: logo + identity ===== */
  .exp-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }
  .exp-logo {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 14px;
    background: #fff;
    border: 1px solid var(--color-border);
    box-shadow: 0 4px 14px -6px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .exp-logo img {
    width: 72%;
    height: 72%;
    object-fit: contain;
  }
  .exp-headings {
    min-width: 0;
  }
  .exp-company {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .exp-role {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.3rem;
    font-size: 0.95rem;
  }
  .exp-role .role {
    color: var(--color-accent);
    font-weight: 600;
  }
  .exp-sep {
    color: var(--color-border);
  }
  .exp-client {
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .exp-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    opacity: 0.85;
  }
  .exp-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .exp-meta-dot {
    opacity: 0.6;
  }

  /* ===== Divider ===== */
  .exp-divider {
    height: 1px;
    background: var(--color-border);
    margin: 1.1rem 0;
    position: relative;
    z-index: 1;
  }

  /* ===== Description bullets ===== */
  .exp-desc {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 1;
  }
  .exp-desc li {
    position: relative;
    padding-left: 1.6rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }
  .exp-desc li::before {
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  /* Per-company bullet markers (5 professional variants to compare) */
  .bullet-chevron li::before {
    content: "›";
    top: -0.05em;
    font-size: 1.05rem;
    line-height: 1.5;
  }
  .bullet-diamond li::before {
    content: "";
    top: 0.55em;
    width: 7px;
    height: 7px;
    background: var(--color-accent);
    transform: rotate(45deg);
    border-radius: 1px;
  }
  .bullet-plus li::before {
    content: "+";
    top: -0.05em;
    font-size: 0.95rem;
  }
  .bullet-arrow li::before {
    content: "→";
    top: 0;
    font-size: 0.85rem;
  }
  .bullet-ring li::before {
    content: "";
    top: 0.5em;
    width: 8px;
    height: 8px;
    border: 2px solid var(--color-accent);
    border-radius: 50%;
  }

  /* ===== Tech chips (tile style, matches sketch) ===== */
  .exp-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.1rem;
    position: relative;
    z-index: 1;
  }
  .exp-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: #fff;
    border: 1px solid var(--color-border);
    box-shadow: 0 2px 8px -4px rgba(0, 0, 0, 0.2);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .exp-card:hover .exp-chip {
    box-shadow: 0 4px 12px -5px rgba(0, 0, 0, 0.28);
  }
  .exp-chip:hover {
    transform: translateY(-2px);
  }
  /* Tech icons sit on a white tile, so never invert in dark mode */
  .exp-chip :global(.tech-dark-invert svg) {
    filter: none;
  }

  /* ===== Secondary roles within the same company ===== */
  .exp-subrole {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--color-border);
    position: relative;
    z-index: 1;
  }
  .exp-subperiod {
    font-size: 0.72rem;
    color: var(--color-accent);
    margin-left: auto;
    white-space: nowrap;
  }
  .exp-subperiod span {
    color: var(--color-text-secondary);
  }

  /* ===== Responsive ===== */
  @media (max-width: 600px) {
    .timeline-item {
      grid-template-columns: 2.6rem 1rem 1fr;
      column-gap: 0.6rem;
    }
    .exp-year {
      font-size: 1rem;
    }
    .exp-card {
      padding: 1.25rem;
    }
    .exp-logo {
      width: 50px;
      height: 50px;
    }
    .exp-header {
      gap: 0.85rem;
    }
    .exp-meta {
      gap: 0.3rem;
    }
  }
</style>
