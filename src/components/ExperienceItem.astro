---
import type { Lang } from "../i18n/i18n";
import { i18nTextLoc } from "../i18n/i18n";
import type { ExperienceEntry, ExperienceRole } from "../data/experience";
import TechIcon from "./TechIcon.astro";
import Icon from "./Icon.astro";
import { withBase } from "../lib/paths";

interface Props {
  entry: ExperienceEntry;
  lang: Lang;
  stagger: number;
}

const { entry, lang, stagger } = Astro.props;

const primary = entry.roles[0];
const extraRoles = entry.roles.slice(1);
const multiRole = extraRoles.length > 0;
const railYear = entry.startYear ?? primary.period.en;
const logoSrc = withBase(`icons/companies/${entry.logo}`);
---

<div class:list={["timeline-item", "animate-on-scroll", `stagger-${stagger}`]}>
  <div class="exp-rail">
    <span class="exp-year">{railYear}</span>
  </div>

  <div class="exp-marker" aria-hidden="true"><span class="exp-dot"></span></div>

  <article id={`exp-${entry.id}`} class="exp-card flashable">
    <img
      src={logoSrc}
      alt=""
      class="exp-bg-icon"
      aria-hidden="true"
      loading="lazy"
    />

    <header class="exp-header" role="button" tabindex="0" aria-expanded="false">
      <div class="exp-headings">
        <h3 class="exp-company">{entry.company}</h3>
        {
          multiRole ? (
            <p class="exp-roles-summary">
              {entry.roles.map((role, i) => (
                <>
                  {i > 0 && <span class="exp-sep">&</span>}
                  <span class="role" {...i18nTextLoc(role.role)}>
                    {role.role[lang]}
                  </span>
                </>
              ))}
            </p>
          ) : (
            <>
              <p class="exp-role">
                <span class="role" {...i18nTextLoc(primary.role)}>
                  {primary.role[lang]}
                </span>
                {primary.client && (
                  <>
                    <span class="exp-sep">|</span>
                    <span class="exp-client">{primary.client}</span>
                  </>
                )}
              </p>
              <p class="exp-meta">
                <span class="exp-meta-item">
                  <Icon name="pin" size={14} />
                  <span {...i18nTextLoc(primary.location)}>
                    {primary.location[lang]}
                  </span>
                </span>
              </p>
            </>
          )
        }
      </div>
      <span class="exp-toggle" aria-hidden="true">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="6 9 12 15 18 9"></polyline></svg
        >
      </span>
    </header>

    <div class="exp-body">
      <div class="exp-body-inner">
        {
          multiRole ? (
            entry.roles.map((role: ExperienceRole, i: number) => (
              <div class:list={["exp-role-section", i > 0 && "exp-subrole"]}>
                <p class="exp-role">
                  <span class="role" {...i18nTextLoc(role.role)}>
                    {role.role[lang]}
                  </span>
                  {role.client && (
                    <>
                      <span class="exp-sep">|</span>
                      <span class="exp-client">{role.client}</span>
                    </>
                  )}
                  <span class="exp-subperiod font-mono">
                    {role.period[lang]}
                  </span>
                </p>
                <p class="exp-meta">
                  <span class="exp-meta-item">
                    <Icon name="pin" size={14} />
                    <span {...i18nTextLoc(role.location)}>
                      {role.location[lang]}
                    </span>
                  </span>
                </p>
                <ul class="exp-desc">
                  {role.description.map((d) => (
                    <li {...i18nTextLoc(d)}>{d[lang]}</li>
                  ))}
                </ul>
                <div class="exp-tech">
                  {role.technologies.map((id) => (
                    <span class="exp-chip">
                      <TechIcon id={id} size={22} />
                    </span>
                  ))}
                </div>
              </div>
            ))
          ) : (
            <>
              <div class="exp-divider" />
              <ul class="exp-desc">
                {primary.description.map((d) => (
                  <li {...i18nTextLoc(d)}>{d[lang]}</li>
                ))}
              </ul>
              <div class="exp-tech">
                {primary.technologies.map((id) => (
                  <span class="exp-chip">
                    <TechIcon id={id} size={22} />
                  </span>
                ))}
              </div>
            </>
          )
        }
      </div>
    </div>
  </article>
</div>

<style>
  .timeline-item {
    display: grid;
    grid-template-columns: 3.25rem 1.5rem 1fr;
    column-gap: 0.85rem;
    padding-bottom: 2.25rem;
  }

  /* ===== Left rail: start year ===== */
  .exp-rail {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding-top: 0.55rem;
  }
  .exp-year {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: -0.02em;
  }

  /* ===== Middle marker: dot + connecting line ===== */
  .exp-marker {
    position: relative;
  }
  .exp-marker::before {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0.9rem;
    bottom: -2.25rem;
    width: 2px;
    background: linear-gradient(var(--color-border) 60%, transparent);
    background-size: 2px 8px;
  }
  .timeline-item:last-child .exp-marker::before {
    display: none;
  }
  .exp-dot {
    position: absolute;
    left: 50%;
    top: 0.6rem;
    transform: translateX(-50%);
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 3px var(--color-glow);
    z-index: 1;
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s;
  }
  .timeline-item:hover .exp-dot {
    transform: translateX(-50%) scale(1.3);
    box-shadow: 0 0 0 5px var(--color-glow);
  }

  /* ===== Card ===== */
  .exp-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem 1.65rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.4s,
      box-shadow 0.4s;
  }
  .exp-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-glow) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
  }
  .exp-card:hover::before {
    opacity: 1;
  }
  .exp-card:hover {
    border-color: var(--color-accent-light);
    transform: translateY(-3px);
    box-shadow: 0 18px 50px -18px var(--color-glow);
  }

  /* ===== Background watermark logo ===== */
  .exp-bg-icon {
    position: absolute;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%) rotate(-6deg);
    width: auto;
    height: auto;
    max-width: 160px;
    max-height: 58px;
    object-fit: contain;
    opacity: 0.1;
    pointer-events: none;
    z-index: 0;
    filter: brightness(0);
    transition:
      opacity 0.45s ease,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .exp-card:hover .exp-bg-icon {
    opacity: 0.22;
    transform: translateY(-50%) rotate(-3deg) scale(1.05);
  }
  :global(.dark) .exp-bg-icon {
    filter: brightness(0) invert(1);
  }
  :global(#exp-nunegal) .exp-bg-icon {
    max-width: 200px;
    max-height: 72px;
  }

  /* ===== Header (clickable toggle) ===== */
  .exp-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
    cursor: pointer;
    user-select: none;
  }
  .exp-header:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 8px;
  }
  .exp-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    color: var(--color-text-secondary);
    opacity: 0.5;
    transition:
      transform 0.3s ease,
      opacity 0.3s;
  }
  .exp-card.expanded .exp-toggle {
    transform: rotate(180deg);
    opacity: 0.8;
  }
  .exp-header:hover .exp-toggle {
    opacity: 0.9;
  }

  /* ===== Headings ===== */
  .exp-headings {
    min-width: 0;
    flex: 1;
  }
  .exp-company {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .exp-role {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.3rem;
    font-size: 0.95rem;
  }
  .exp-role .role {
    color: var(--color-accent);
    font-weight: 600;
  }
  .exp-sep {
    color: var(--color-border);
  }
  .exp-client {
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .exp-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    opacity: 0.85;
  }
  .exp-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .exp-roles-summary {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.3rem;
    font-size: 0.9rem;
  }
  .exp-role-section:first-child {
    margin-top: 0.75rem;
  }

  /* ===== Collapsible body ===== */
  .exp-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
    position: relative;
    z-index: 1;
  }
  .exp-body-inner {
    overflow: hidden;
    opacity: 0;
    transform: translateY(-6px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }
  .exp-card.expanded .exp-body {
    grid-template-rows: 1fr;
  }
  .exp-card.expanded .exp-body-inner {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.35s ease 0.12s,
      transform 0.35s ease 0.12s;
  }

  /* ===== Divider ===== */
  .exp-divider {
    height: 1px;
    background: var(--color-border);
    margin: 1.1rem 0;
  }

  /* ===== Description bullets (chevron) ===== */
  .exp-desc {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .exp-desc li {
    position: relative;
    padding-left: 1.6rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }
  .exp-desc li::before {
    content: "›";
    position: absolute;
    left: 0;
    top: -0.05em;
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--color-accent);
    font-weight: 700;
  }

  /* ===== Tech chips ===== */
  .exp-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.1rem;
    padding-bottom: 0.25rem;
  }
  .exp-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: #fff;
    border: 1px solid var(--color-border);
    box-shadow: 0 2px 8px -4px rgba(0, 0, 0, 0.2);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .exp-card:hover .exp-chip {
    box-shadow: 0 4px 12px -5px rgba(0, 0, 0, 0.28);
  }
  .exp-chip:hover {
    transform: translateY(-2px);
  }
  .exp-chip :global(.tech-dark-invert svg) {
    filter: none;
  }

  /* ===== Secondary roles ===== */
  .exp-subrole {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--color-border);
  }
  .exp-subperiod {
    font-size: 0.72rem;
    color: var(--color-accent);
    margin-left: auto;
    white-space: nowrap;
    font-weight: 600;
  }

  @media (prefers-reduced-motion: reduce) {
    .exp-body,
    .exp-body-inner {
      transition: none;
    }
    .timeline-item:hover .exp-dot {
      transform: translateX(-50%);
    }
  }

  /* ===== Responsive ===== */
  @media (max-width: 600px) {
    .timeline-item {
      grid-template-columns: 2.6rem 1rem 1fr;
      column-gap: 0.6rem;
    }
    .exp-year {
      font-size: 1rem;
    }
    .exp-card {
      padding: 1.25rem;
    }
    .exp-bg-icon {
      max-width: 110px;
      max-height: 42px;
      right: 0.75rem;
      opacity: 0.08;
    }
    :global(#exp-nunegal) .exp-bg-icon {
      max-width: 140px;
      max-height: 52px;
    }
    .exp-header {
      gap: 0.85rem;
    }
    .exp-meta {
      gap: 0.3rem;
    }
  }
</style>

<script>
  function initExpCards() {
    document.querySelectorAll<HTMLElement>(".exp-header").forEach((header) => {
      const card = header.closest<HTMLElement>(".exp-card");
      if (!card) return;

      function toggle() {
        const expanded = card!.classList.toggle("expanded");
        header.setAttribute("aria-expanded", String(expanded));
      }

      header.addEventListener("click", toggle);
      header.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          toggle();
        }
      });
    });

    function expandFromHash() {
      const hash = location.hash;
      if (!hash) return;
      const target = document.querySelector<HTMLElement>(hash);
      if (!target?.classList.contains("exp-card")) return;
      if (!target.classList.contains("expanded")) {
        target.classList.add("expanded");
        const header = target.querySelector<HTMLElement>(".exp-header");
        header?.setAttribute("aria-expanded", "true");
      }
      requestAnimationFrame(() => {
        target.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    }

    expandFromHash();
    window.addEventListener("hashchange", expandFromHash);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initExpCards);
  } else {
    initExpCards();
  }
</script>
