---
import type { Lang } from "../i18n/i18n";
import type { ExperienceEntry } from "../data/experience";
import TechIcon from "./TechIcon.astro";

interface Props {
  entry: ExperienceEntry;
  lang: Lang;
  stagger: number;
}

const { entry, lang, stagger } = Astro.props;
---

<div
  class:list={["timeline-item", "filter-match", "animate-on-scroll", `stagger-${stagger}`]}
  data-technologies={entry.technologies.join(",")}
>
  <span class="timeline-period font-mono">{entry.period[lang]}</span>
  <h3 class="timeline-company">
    {entry.company}
    {entry.client && <span class="timeline-client">· {entry.client}</span>}
  </h3>
  <p class="timeline-role">{entry.role[lang]} · {entry.location[lang]}</p>
  <ul class="timeline-desc">
    {entry.description.map((d) => <li>{d[lang]}</li>)}
  </ul>
  <div class="timeline-tech">
    {entry.technologies.map((id) => <TechIcon id={id} size={20} mini />)}
  </div>
</div>

<style>
  .timeline-item {
    position: relative;
    padding-left: 2rem;
    padding-bottom: 3rem;
  }
  .timeline-item::before {
    content: "";
    position: absolute;
    left: -5px;
    top: 6px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 3px var(--color-glow);
  }
  .timeline-period {
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 500;
  }
  .timeline-company {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0.25rem 0;
  }
  .timeline-client {
    font-weight: 500;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }
  .timeline-role {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }
  .timeline-desc {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
  }
  .timeline-desc li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 0.35rem;
  }
  .timeline-desc li::before {
    content: "–";
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }
  .timeline-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }
</style>
