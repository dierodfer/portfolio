---
import type { Lang } from "../i18n/i18n";
import { t } from "../i18n/i18n";
import { personal } from "../data/personal";
import Section from "./Section.astro";
import Icon from "./Icon.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const links = [
  {
    label: t("contact.emailLabel", lang),
    value: personal.email,
    href: `mailto:${personal.email}`,
    icon: "mail" as const,
    external: false,
  },
  {
    label: t("contact.githubLabel", lang),
    value: "@dierodfer",
    href: personal.github,
    icon: "github" as const,
    external: true,
  },
  {
    label: t("contact.linkedinLabel", lang),
    value: "/in/diegorodfer",
    href: personal.linkedin,
    icon: "linkedin" as const,
    external: true,
  },
];
---

<Section id="contacto" tag={t("sections.contactTag", lang)} title={t("sections.contactTitle", lang)}>
  <div class="contact-grid">
    {
      links.map((l, i) => (
        <a
          href={l.href}
          target={l.external ? "_blank" : undefined}
          rel="noopener"
          class:list={["contact-card", "animate-on-scroll", `stagger-${i + 1}`]}
        >
          <span class="contact-icon">
            <Icon name={l.icon} />
          </span>
          <span class="contact-label">{l.label}</span>
          <span class="contact-value">{l.value}</span>
        </a>
      ))
    }
  </div>
</Section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }
  .contact-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent-light);
    box-shadow: 0 16px 40px -10px var(--color-glow);
  }
  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--color-glow);
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .contact-label {
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .contact-value {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
