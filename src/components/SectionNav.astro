---
import type { Lang, TranslationKey } from "../i18n/i18n";
import { t, i18nText, i18nAttr } from "../i18n/i18n";
import { navItems } from "../data/navigation";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<nav class="section-nav" aria-label="Sections">
  <ul>
    {
      navItems.map((item) => {
        const key = `nav.${item.key}` as TranslationKey;
        return (
          <li>
            <a
              href={item.href}
              class="dot"
              data-section={item.href.slice(1)}
              aria-label={t(key, lang)}
              {...i18nAttr("aria-label", key)}
            >
              <span class="dot-label" {...i18nText(key)}>
                {t(key, lang)}
              </span>
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .section-nav {
    position: fixed;
    top: 50%;
    right: 1.4rem;
    transform: translateY(-50%);
    z-index: 60;
  }
  .section-nav ul {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .dot {
    position: relative;
    display: block;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent);
    opacity: 0.5;
    transition:
      opacity 0.3s,
      transform 0.3s,
      background 0.3s;
  }
  .dot:hover {
    opacity: 1;
  }
  .dot.active {
    opacity: 1;
    background: var(--color-accent);
    transform: scale(1.25);
  }
  .dot-label {
    position: absolute;
    right: calc(100% + 0.65rem);
    top: 50%;
    transform: translateY(-50%) translateX(6px);
    white-space: nowrap;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 7px;
    padding: 0.2rem 0.55rem;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.25s,
      transform 0.25s;
  }
  .dot:hover .dot-label,
  .dot:focus-visible .dot-label {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }
  @media (max-width: 768px) {
    .section-nav {
      display: none;
    }
  }
</style>

<script>
  const dots = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(".section-nav .dot"),
  );
  const byId = new Map(dots.map((d) => [d.dataset.section, d]));
  const scroller = document.querySelector<HTMLElement>("main");
  const sections = document.querySelectorAll<HTMLElement>("main > section[id]");

  const spy = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          dots.forEach((d) => d.classList.remove("active"));
          byId.get(entry.target.id)?.classList.add("active");
        }
      });
    },
    // Observe against the <main> scroll container, not the viewport.
    { root: scroller, threshold: 0.5 },
  );
  sections.forEach((s) => spy.observe(s));

  // Native fragment navigation is unreliable inside a non-document scroll
  // container, so drive it explicitly via scrollIntoView on the scroller.
  dots.forEach((dot) => {
    dot.addEventListener("click", (e) => {
      const href = dot.getAttribute("href");
      const target = href ? document.querySelector<HTMLElement>(href) : null;
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
      history.pushState(null, "", href);
    });
  });
</script>
