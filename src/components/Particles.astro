---
// Subtle themed background particles on a <canvas>. Vanilla, zero-dependency.
// Renders a slow-drifting "constellation": points joined by thin lines when
// near. Colour is read from --color-accent and re-read on theme toggle, and
// the animation honors prefers-reduced-motion (single static frame).
---

<canvas id="bg-particles" aria-hidden="true"></canvas>

<style>
  #bg-particles {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: -1;
  }
</style>

<script>
  const canvas = document.getElementById(
    "bg-particles",
  ) as HTMLCanvasElement | null;

  if (canvas) {
    const ctx = canvas.getContext("2d")!;
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    // Theme-driven colour as an "r,g,b" string, re-read on theme change.
    let rgb = "148,163,184";
    const hexToRgb = (hex: string): string | null => {
      const m = hex.replace("#", "").trim();
      if (m.length !== 6) return null;
      const r = parseInt(m.slice(0, 2), 16);
      const g = parseInt(m.slice(2, 4), 16);
      const b = parseInt(m.slice(4, 6), 16);
      if ([r, g, b].some(Number.isNaN)) return null;
      return `${r},${g},${b}`;
    };
    const readColor = () => {
      const v = getComputedStyle(document.documentElement)
        .getPropertyValue("--color-accent")
        .trim();
      rgb = hexToRgb(v) || rgb;
    };

    let w = 0;
    let h = 0;
    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = window.innerWidth;
      h = window.innerHeight;
      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      r: number;
    }
    let points: Particle[] = [];
    const rand = (a: number, b: number) => a + Math.random() * (b - a);

    const build = () => {
      const count = Math.min(w < 768 ? 28 : 80, Math.round((w * h) / 18000));
      points = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: rand(-0.18, 0.18),
        vy: rand(-0.18, 0.18),
        r: rand(0.8, 2),
      }));
    };

    const draw = () => {
      ctx.clearRect(0, 0, w, h);
      const max = 120;
      ctx.lineWidth = 1;
      for (let i = 0; i < points.length; i++) {
        for (let j = i + 1; j < points.length; j++) {
          const a = points[i];
          const b = points[j];
          const d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < max) {
            ctx.strokeStyle = `rgba(${rgb},${0.18 * (1 - d / max)})`;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }
      ctx.fillStyle = `rgba(${rgb},0.5)`;
      for (const p of points) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
    };

    let raf = 0;
    const frame = () => {
      for (const p of points) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -60) p.x = w + 60;
        else if (p.x > w + 60) p.x = -60;
        if (p.y < -60) p.y = h + 60;
        else if (p.y > h + 60) p.y = -60;
      }
      draw();
      raf = requestAnimationFrame(frame);
    };

    const start = () => {
      cancelAnimationFrame(raf);
      if (reduceMotion) {
        draw(); // single static frame, no animation
        return;
      }
      raf = requestAnimationFrame(frame);
    };

    window.addEventListener(
      "resize",
      () => {
        resize();
        build();
        start();
      },
      { passive: true },
    );

    // Recolour on theme toggle (.dark class flips on <html>).
    new MutationObserver(readColor).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    readColor();
    resize();
    build();
    start();
  }
</script>
