---
// Subtle gradient divider between sections.
---

<div class="divider" role="separator"></div>

<style>
  .divider {
    height: 1px;
    max-width: 1200px;
    margin: 5rem auto;
    padding: 0;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-accent-light),
      transparent
    );
    opacity: 0.3;
  }
  @media (max-width: 768px) {
    .divider { margin: 3rem auto; }
  }
</style>
