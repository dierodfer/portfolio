---
import type { Lang } from "../i18n/i18n";
import { experience } from "../data/experience";
import Section from "./Section.astro";
import ExperienceItem from "./ExperienceItem.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<Section
  id="experiencia"
  lang={lang}
  tagKey="sections.experienceTag"
  titleKey="sections.experienceTitle"
  narrow
>
  <div class="timeline">
    {
      experience.map((entry, i) => (
        <ExperienceItem entry={entry} lang={lang} stagger={(i % 7) + 1} />
      ))
    }
  </div>
</Section>

<style>
  .timeline {
    position: relative;
  }
</style>
