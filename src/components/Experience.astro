---
import type { Lang } from "../i18n/i18n";
import { t } from "../i18n/i18n";
import { experience } from "../data/experience";
import ExperienceItem from "./ExperienceItem.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="experiencia" class="section">
  <div class="container">
    <p class="section-tag font-mono animate-on-scroll">{t("sections.experienceTag", lang)}</p>
    <h2 class="section-heading animate-on-scroll">{t("sections.experienceTitle", lang)}</h2>

    <div class="timeline">
      {
        experience.map((entry, i) => (
          <ExperienceItem entry={entry} lang={lang} stagger={(i % 7) + 1} />
        ))
      }
    </div>
  </div>
</section>

<style>
  .section { padding: 2rem 0; }
  .container {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .section-tag {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .section-heading {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
  }
  .timeline {
    position: relative;
    padding-left: 0.5rem;
    border-left: 1px solid var(--color-border);
  }
</style>
