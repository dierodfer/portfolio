---
import type { Lang } from "../i18n/i18n";
import { t } from "../i18n/i18n";
import { experience } from "../data/experience";
import Section from "./Section.astro";
import ExperienceItem from "./ExperienceItem.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<Section id="experiencia" tag={t("sections.experienceTag", lang)} title={t("sections.experienceTitle", lang)} narrow>
  <div class="timeline">
    {
      experience.map((entry, i) => (
        <ExperienceItem entry={entry} lang={lang} stagger={(i % 7) + 1} />
      ))
    }
  </div>
</Section>

<style>
  .timeline {
    position: relative;
    padding-left: 0.5rem;
    border-left: 1px solid var(--color-border);
  }
</style>
