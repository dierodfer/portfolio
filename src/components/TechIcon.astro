---
import { techById, assertTechIds } from "../data/technologies";
import { withBase } from "../lib/paths";

interface Props {
  id: string;
  size?: number;
  mini?: boolean;
}

const { id, size = 24, mini = false } = Astro.props;
assertTechIds([id], `TechIcon(${id})`);
const tech = techById[id];
---

{
  tech && (
    <img
      src={withBase(`icons/tech/${tech.icon}`)}
      alt={tech.name}
      title={tech.name}
      width={size}
      height={size}
      loading="lazy"
      class:list={["tech-img", mini && "tech-mini"]}
      style={`width:${size}px;height:${size}px`}
    />
  )
}
