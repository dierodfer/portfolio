---
import type { Lang } from "../i18n/i18n";
import { t } from "../i18n/i18n";
import { personal } from "../data/personal";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer">
  <p>{t("footer.designedBy", lang)} <strong>{personal.name}</strong> · © {year}</p>
  <p class="footer-sub font-mono">{t("footer.builtWith", lang)}</p>
</footer>

<style>
  .footer {
    text-align: center;
    padding: 3rem 2rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
  .footer-sub {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    opacity: 0.7;
  }
</style>
